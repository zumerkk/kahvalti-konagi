// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum ReservationStatus {
  PENDING
  BOOKED       // Legacy or Onaylandı
  CONFIRMED    // Onaylandı
  ARRIVED
  SEATED
  COMPLETED
  CANCELLED
  NO_SHOW
  POSTPONED
  DEPOSIT_PENDING
  DEPOSIT_RECEIVED
}

enum ServiceType {
  BREAKFAST
  CAFE
}

enum AreaCode {
  CAMEKAN
  SALON
}

enum ReservationSource {
  WEB
  PHONE
  WHATSAPP
  INSTAGRAM
  WALK_IN
  ADMIN
  OTHER
}

enum Role {
  SUPER_ADMIN
  MANAGER
  STAFF
}

model User {
  id           String   @id @default(cuid())
  username     String   @unique
  passwordHash String
  role         Role     @default(STAFF)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Area {
  id        String   @id @default(cuid())
  code      AreaCode @unique
  title     String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tables Table[]
  reservations Reservation[]
}

model Table {
  id        String        @id @default(cuid())
  name      String
  isActive  Boolean       @default(true)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  areaId String
  area   Area   @relation(fields: [areaId], references: [id], onDelete: Restrict)

  reservations Reservation[]
  orders       Order[]

  @@unique([areaId, name])
}

model Reservation {
  id            String            @id @default(cuid())
  status        ReservationStatus @default(PENDING)
  source        ReservationSource @default(WEB)
  serviceType   ServiceType       @default(BREAKFAST)

  /// Rezervasyon tarihi (saat içermez)
  date          DateTime          @db.Date
  /// 24 saat formatında saat: "08:00" - "14:00"
  time          String

  tableId       String
  table         Table             @relation(fields: [tableId], references: [id], onDelete: Restrict)

  fullName      String
  phone         String
  /// KVKK açısından hassas veri: şifreli saklanır
  tcknEncrypted String?
  tcknLast4     String?

  partySize     Int
  totalAmount   Int?
  note          String?

  areaId        String
  area          Area              @relation(fields: [areaId], references: [id], onDelete: Restrict)

  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  orders        Order[]

  @@index([serviceType, date, time])
  @@index([status])
}

model Order {
  id            String      @id @default(cuid())
  tableId       String
  table         Table       @relation(fields: [tableId], references: [id], onDelete: Restrict)
  
  reservationId String?
  reservation   Reservation? @relation(fields: [reservationId], references: [id], onDelete: SetNull)

  status        String      @default("OPEN") // OPEN, CLOSED, CANCELLED
  totalAmount   Int         @default(0) // Kuruş
  
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  items         OrderItem[]
  payments      Payment[]

  @@index([tableId])
  @@index([status])
}

model OrderItem {
  id        String   @id @default(cuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Restrict)
  
  quantity  Int      @default(1)
  priceCents Int     // Fiyat o andaki ürün fiyatıdır (Kuruş)
  note      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orderId])
  @@index([productId])
}

model Payment {
  id        String   @id @default(cuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  
  amountCents Int
  method      String // CASH, CREDIT_CARD, IBAN, OTHER
  status      String @default("COMPLETED") // PENDING, COMPLETED, REFUNDED

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orderId])
}

model AuditLog {
  id        String   @id @default(cuid())
  entity    String   // RESERVATION, SETTINGS, ORDER, etc.
  entityId  String
  action    String   // CREATE, UPDATE, DELETE, STATUS_CHANGE
  details   String?  // JSON stringified details
  adminUser String?  // Kim yaptı?
  
  createdAt DateTime @default(now())

  @@index([entity, entityId])
}

model ClosedDate {
  id        String   @id @default(cuid())
  date      DateTime @unique @db.Date
  reason    String?
  createdAt DateTime @default(now())
}

model Category {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  products Product[]
}

model Product {
  id          String   @id @default(cuid())
  categoryId  String
  name        String
  description String?
  imageUrl    String?
  /// Para birimi: kuruş (örn. 1990 = 19,90₺). Açık büfe gibi sabit fiyatlı ürünlerde null bırakılabilir.
  priceCents  Int?
  stockQty    Int      @default(0)
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  sku         String?  @unique /// Hızlı Satış ve Barkod Entegrasyonu için
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  category Category @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  orderItems OrderItem[]
  variants   ProductVariant[]

  @@index([categoryId])
  @@index([isActive])
}

model ProductVariant {
  id         String   @id @default(cuid())
  productId  String
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  name       String   // Örn: "Büyük Porsiyon", "Şekersiz"
  priceCents Int
  stockQty   Int      @default(0)
  sku        String?  @unique // Barkod
  isActive   Boolean  @default(true)

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([productId])
}

model Settings {
  /// Tek satır (singleton) ayarlar tablosu
  id                   String   @id @default("singleton")
  businessName         String   @default("Kahvaltı Konağı")
  phone                String?
  whatsapp             String?
  address              String?

  reservationsEnabled  Boolean  @default(true)
  onlineReservationsActive Boolean @default(true)
  
  reservationStartTime String   @default("08:00")
  reservationEndTime   String   @default("14:00")
  cafeStartTime        String   @default("14:00")
  cafeEndTime          String   @default("23:00")
  
  slotMinutes          Int      @default(30)
  minPartySize         Int      @default(1)
  maxPartySize         Int      @default(4)
  breakfastPricePerPerson Int   @default(350)
  
  depositEnabled       Boolean  @default(false)
  depositAmount        Int      @default(0)
  
  smsEnabled           Boolean  @default(false)
  emailEnabled         Boolean  @default(false)

  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}
